# Copy this file to .env and fill in your AnkiWeb account.
# Do not commit .env.

ANKICONNECT_ANKIWEB_USER=your@email.com
ANKICONNECT_ANKIWEB_PASS=your_password

# Optional: set to true if /vault is a git checkout and you want every sync loop to pull first.
YANKI_GIT_PULL=false

# Optional: run one sync and exit.
YANKI_ONCE=false
