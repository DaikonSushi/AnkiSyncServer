# Copy this file to .env and fill in your AnkiWeb account.
# Do not commit .env.

ANKICONNECT_ANKIWEB_USER=your@email.com
ANKICONNECT_ANKIWEB_PASS=your_password

# Obsidian vault Git settings.
YANKI_GIT_PULL=true
OBSIDIAN_GIT_REPO=git@github.com:DaikonSushi/MyObsidian.git
OBSIDIAN_GIT_BRANCH=main
OBSIDIAN_GIT_DIR=/vault

# Optional: run one sync and exit.
YANKI_ONCE=false
